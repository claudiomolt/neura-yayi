{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "vercel-dev",
      "runtimeExecutable": "vercel",
      "runtimeArgs": ["dev", "--listen", "3000"],
      "port": 3000
    },
    {
      "name": "npx-serve",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-l", "4173"],
      "port": 4173
    },
    {
      "name": "python-http",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    }
  ]
}
